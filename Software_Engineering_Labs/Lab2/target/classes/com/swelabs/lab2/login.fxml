<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<!--
    Login screen layout for Lab 2.
    Controller: com.swelabs.lab2.LoginController
    Contains: title label, username field, password field, login button, error label.
-->
<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.swelabs.lab2.LoginController"
      alignment="CENTER"
      spacing="16"
      style="-fx-background-color: #1e1e2e;">

    <padding>
        <Insets top="40" right="50" bottom="40" left="50"/>
    </padding>

    <!-- Title -->
    <Label text="GCM System Login"
           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #cdd6f4;
                  -fx-font-family: 'Segoe UI';"/>

    <Label text="Please enter your credentials"
           style="-fx-font-size: 13px; -fx-text-fill: #a6adc8; -fx-font-family: 'Segoe UI';"/>

    <!-- Username field -->
    <TextField fx:id="usernameField"
               promptText="Email (username)"
               style="-fx-background-color: #313244; -fx-text-fill: #cdd6f4;
                      -fx-prompt-text-fill: #6c7086; -fx-background-radius: 8;
                      -fx-border-radius: 8; -fx-padding: 10 14; -fx-font-size: 13px;
                      -fx-font-family: 'Segoe UI';"
               maxWidth="320"/>

    <!-- Password field -->
    <PasswordField fx:id="passwordField"
                   promptText="Password"
                   style="-fx-background-color: #313244; -fx-text-fill: #cdd6f4;
                          -fx-prompt-text-fill: #6c7086; -fx-background-radius: 8;
                          -fx-border-radius: 8; -fx-padding: 10 14; -fx-font-size: 13px;
                          -fx-font-family: 'Segoe UI';"
                   maxWidth="320"/>

    <!-- Login button -->
    <Button fx:id="loginButton"
            text="Login"
            onAction="#handleLogin"
            defaultButton="true"
            style="-fx-background-color: #89b4fa; -fx-text-fill: #1e1e2e;
                   -fx-font-weight: bold; -fx-font-size: 14px; -fx-font-family: 'Segoe UI';
                   -fx-background-radius: 8; -fx-padding: 10 40; -fx-cursor: hand;"
            maxWidth="320"/>

    <!-- Error label: hidden until a login attempt fails -->
    <Label fx:id="errorLabel"
           text=""
           visible="false"
           wrapText="true"
           style="-fx-text-fill: #f38ba8; -fx-font-size: 12px; -fx-font-family: 'Segoe UI';"
           maxWidth="320"/>

</VBox>
